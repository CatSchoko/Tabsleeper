{
  "manifest_version": 3,
  "name": "Tab Sleeper",
  "version": "1.2.0",
  "description": "Legt lange ungenutzte Tabs schlafen, um Arbeitsspeicher zu sparen. Aufwachen nur per Wake-Button.",
  "permissions": ["tabs", "storage", "alarms", "contextMenus", "scripting"],
  "host_permissions": ["*://*.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Sleeper"
  },
  "options_page": "popup.html",
  "commands": {
    "sleep-current-tab": {
      "suggested_key": { "default": "Alt+S" },
      "description": "Aktuellen Tab sofort schlafen legen"
    }
  }
}
